class Producto:
    def __init__(self, codigo, nombre, precio, stock):
        self.codigo = codigo
        self.nombre = nombre
        self.precio = precio
        self.stock = stock

    def mostrar(self):
        return f"{self.codigo} - {self.nombre} - ${self.precio} - Stock: {self.stock}"


class Cliente:
    def __init__(self, nombre, correo):
        self.nombre = nombre
        self.correo = correo


class Pago:
    def __init__(self, tipo="Tarjeta de crédito"):
        self.tipo = tipo
        self.numero_tarjeta = ""

    def ingresar_tarjeta(self):
        self.numero_tarjeta = input("Ingrese el número de la tarjeta: ")

    def procesar_pago(self, monto):
        self.ingresar_tarjeta()
        print(f"Pago de ${monto} realizado con {self.tipo}")
        print(f"Tarjeta usada: ****{self.numero_tarjeta[-4:]}")


class Queja:
    def __init__(self, cliente, mensaje):
        self.cliente = cliente
        self.mensaje = mensaje

    def enviar(self):
        print(f"Queja enviada a nuestra gerente: {self.mensaje}")


class Transporte:
    def __init__(self, nombre):
        self.nombre = nombre

    def enviar_pedido(self, orden):
        print(f"Pedido enviado por {self.nombre} al cliente {orden.cliente.nombre}")


class Orden:
    def __init__(self, cliente):
        self.cliente = cliente
        self.productos = []
        self.estado = "Activa"
        self.pago = None

    def agregar_producto(self, producto):
        if producto.stock > 0:
            self.productos.append(producto)
            producto.stock -= 1
            print("Producto agregado")
        else:
            print("Sin stock")

    def cancelar(self):
        self.estado = "Cancelada"
        print("Orden cancelada")

    def calcular_total(self):
        total = 0
        for p in self.productos:
            total += p.precio
        return total

    def realizar_pago(self):
        total = self.calcular_total()
        self.pago = Pago()
        self.pago.procesar_pago(total)

    def mostrar(self):
        print(f"\nCliente: {self.cliente.nombre}")
        print("Productos:")
        for p in self.productos:
            print(f"- {p.nombre}")
        print(f"Total: ${self.calcular_total()}")
        print(f"Estado: {self.estado}")


class Sistema:
    def __init__(self):
        self.productos = []
        self.ordenes = []
        self.quejas = []

    def agregar_producto(self, producto):
        self.productos.append(producto)

    def mostrar_catalogo(self):
        print("\nCATÁLOGO")
        for p in self.productos:
            print(p.mostrar())

    def buscar_producto(self, codigo):
        for p in self.productos:
            if p.codigo == codigo:
                return p
        return None

    def enviar_catalogo(self, cliente):
        print(f"Catálogo enviado al correo: {cliente.correo}")

    def crear_orden(self, cliente):
        orden = Orden(cliente)
        self.ordenes.append(orden)
        return orden

    def registrar_queja(self, cliente, mensaje):
        q = Queja(cliente, mensaje)
        self.quejas.append(q)
        q.enviar()
    
def main():
    transportes = [
    Transporte("Servientrega"),
