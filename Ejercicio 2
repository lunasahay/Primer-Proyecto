from datetime import datetime

class Obra:
    def __init__(self, nombre, autor, periodo, fecha_creacion, fecha_ingreso, valor, estilo, descripcion):
        self.nombre = nombre
        self.autor = autor
        self.periodo = periodo
        self.fecha_creacion = fecha_creacion
        self.fecha_ingreso = fecha_ingreso
        self.valor = valor
        self.estilo = estilo
        self.descripcion = descripcion
        self.estado = "Expuesta"
        self.restauraciones = []
        self.prestada = False

    def necesita_restauracion(self):
        años = (datetime.now() - self.fecha_ingreso).days / 365
        return años >= 5

    def enviar_restauracion(self, tipo):
        self.estado = "Restauración"
        fecha_inicio = datetime.now()
        self.restauraciones.append((tipo, fecha_inicio, None))
        print("Obra enviada a restauración")

    def finalizar_restauracion(self):
        if self.restauraciones:
            tipo, inicio, _ = self.restauraciones[-1]
            self.restauraciones[-1] = (tipo, inicio, datetime.now())
            self.estado = "Expuesta"
            print("Restauración finalizada")

    def ver_historial(self):
        print("\nHistorial de restauraciones:")
        for tipo, inicio, fin in self.restauraciones:
            print(f"Tipo: {tipo} | Inicio: {inicio} | Fin: {fin}")

class Cuadro(Obra):
    def __init__(self, nombre, autor, periodo, fecha_creacion, fecha_ingreso, valor, estilo, tecnica, descripcion):
        super().__init__(nombre, autor, periodo, fecha_creacion, fecha_ingreso, valor, estilo, descripcion)
        self.tecnica = tecnica


class Escultura(Obra):
    def __init__(self, nombre, autor, periodo, fecha_creacion, fecha_ingreso, valor, estilo, material, descripcion):
        super().__init__(nombre, autor, periodo, fecha_creacion, fecha_ingreso, valor, estilo, descripcion)
        self.material = material


class OtroObjeto(Obra):
    def __init__(self, nombre, autor, periodo, fecha_creacion, fecha_ingreso, valor, estilo, descripcion):
        super().__init__(nombre, autor, periodo, fecha_creacion, fecha_ingreso, valor, estilo, descripcion)

class Usuario:
    def __init__(self, user, password):
        self.user = user
        self.password = password

    def login(self, user, password):
        return self.user == user and self.password == password

class Museo:
    def __init__(self):
        self.obras = []
        self.museos_colaboradores = ["Museo Nacional", "Louvre", "Prado"]

    def agregar_obra(self, obra):
        self.obras.append(obra)

    def mostrar_obras(self):
        for i, obra in enumerate(self.obras):
            print(f"\n--- OBRA {i + 1} ---")
            print(f"Nombre: {obra.nombre}")
            print(f"Autor: {obra.autor}")
            print(f"Periodo: {obra.periodo}")
            print(f"Estilo: {obra.estilo}")
            print(f"Valor: ${obra.valor}")
            print(f"Estado: {obra.estado}")
            print(f"Descripción: {obra.descripcion}")

    def revisar_restauraciones(self):
        for obra in self.obras:
            if obra.necesita_restauracion():
                print(f"Obra de {obra.nombre} necesita restauración")

    def valor_total(self):
        return sum(obra.valor for obra in self.obras)

    def mostrar_museos(self):
        print("\nMuseos disponibles:")
        for i, m in enumerate(self.museos_colaboradores):
            print(f"{i + 1}. {m}")

class Prestamo:
    def __init__(self, obra, museo_destino, valor, dias):
        self.obra = obra
        self.museo_destino = museo_destino
        self.valor = valor
        self.dias = dias

    def realizar(self):
        if self.obra.prestada:
            print("La obra ya fue prestada")
        else:
            self.obra.prestada = True
            print(f"Obra prestada a {self.museo_destino} por {self.dias} días. Valor: ${self.valor}")

